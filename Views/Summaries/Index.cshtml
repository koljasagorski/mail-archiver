@using MailArchiver.Models
@model MailArchiver.Models.ViewModels.SummariesViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["AiSummaries"];

    string CategoryBadgeClass(string category) => category switch
    {
        SummaryItemCategory.Urgent => "bg-danger",
        SummaryItemCategory.Action => "bg-warning text-dark",
        SummaryItemCategory.Newsletter => "bg-secondary",
        _ => "bg-info text-dark"
    };

    string CategoryLabel(string category) => category switch
    {
        SummaryItemCategory.Urgent => Localizer["SummaryCategoryUrgent"].Value,
        SummaryItemCategory.Action => Localizer["SummaryCategoryAction"].Value,
        SummaryItemCategory.Newsletter => Localizer["SummaryCategoryNewsletter"].Value,
        _ => Localizer["SummaryCategoryInfo"].Value
    };
}

<div class="container-fluid">
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="bi bi-stars me-2"></i>@Localizer["AiSummaries"]
        </h1>
        @if (Model.FeatureEnabled && Model.ApiKeyConfigured)
        {
            <form asp-action="Generate" method="post" class="mb-0"
                  onsubmit="var b=this.querySelector('button');b.disabled=true;b.querySelector('.spinner-border').classList.remove('d-none');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary" title="@Localizer["GenerateSummaryHint"]">
                    <span class="spinner-border spinner-border-sm me-1 d-none" role="status" aria-hidden="true"></span>
                    <i class="bi bi-magic me-1"></i>@Localizer["GenerateSummaryNow"]
                </button>
            </form>
        }
    </div>

    @if (Model.FeatureEnabled && Model.ApiKeyConfigured)
    {
        <p class="text-muted">
            <i class="bi bi-clock me-1"></i>@string.Format(Localizer["SummariesScheduleInfo"].Value, Model.DailyExecutionTime)
        </p>

        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-chat-left-text me-1"></i>@Localizer["AskArchive"]
                </h6>
            </div>
            <div class="card-body">
                <form id="ask-archive-form">
                    @Html.AntiForgeryToken()
                    <div class="input-group">
                        <input type="text" class="form-control" id="ask-archive-question" maxlength="2000"
                               placeholder="@Localizer["AskArchivePlaceholder"]" autocomplete="off" />
                        <button class="btn btn-primary" type="submit" id="ask-archive-btn">
                            <span class="spinner-border spinner-border-sm me-1 d-none" role="status" aria-hidden="true"></span>
                            <i class="bi bi-send me-1"></i>@Localizer["AskArchiveButton"]
                        </button>
                    </div>
                    <small class="text-muted">@Localizer["AskArchiveHint"]</small>
                </form>
                <div id="ask-archive-result" class="mt-3 d-none border-start border-3 border-primary ps-3"></div>
            </div>
        </div>

        <script>
            (function () {
                var form = document.getElementById('ask-archive-form');
                var input = document.getElementById('ask-archive-question');
                var btn = document.getElementById('ask-archive-btn');
                var spinner = btn.querySelector('.spinner-border');
                var resultBox = document.getElementById('ask-archive-result');

                form.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    var question = input.value.trim();
                    if (!question || btn.disabled) return;

                    btn.disabled = true;
                    spinner.classList.remove('d-none');
                    resultBox.classList.remove('d-none');
                    resultBox.innerHTML = '';
                    var working = document.createElement('em');
                    working.className = 'text-muted';
                    working.textContent = '@Localizer["AskArchiveWorking"]';
                    resultBox.appendChild(working);

                    try {
                        var formData = new FormData();
                        formData.append('question', question);
                        formData.append('__RequestVerificationToken',
                            form.querySelector('input[name="__RequestVerificationToken"]').value);

                        var response = await fetch('@Url.Action("Ask")', { method: 'POST', body: formData });
                        var data = await response.json();

                        if (data.success) {
                            resultBox.innerHTML = data.answerHtml;
                        } else {
                            resultBox.innerHTML = '';
                            var err = document.createElement('span');
                            err.className = 'text-danger';
                            err.textContent = data.error || 'Error';
                            resultBox.appendChild(err);
                        }
                    } catch (ex) {
                        resultBox.innerHTML = '';
                        var err2 = document.createElement('span');
                        err2.className = 'text-danger';
                        err2.textContent = String(ex);
                        resultBox.appendChild(err2);
                    } finally {
                        btn.disabled = false;
                        spinner.classList.add('d-none');
                    }
                });
            })();
        </script>
    }
    else if (!Model.Summaries.Any())
    {
        @* Summaries can also be pushed by an external routine via POST /api/v1/summaries,
           so only show the setup hint as long as the page is completely empty *@
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localizer["SummariesDisabledWarning"]
        </div>
    }

    @if (!Model.Summaries.Any())
    {
        <div class="card shadow mb-4">
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-journal-text display-4 d-block mb-3"></i>
                @Localizer["NoSummariesYet"]
            </div>
        </div>
    }

    @foreach (var display in Model.Summaries)
    {
        var summary = display.Summary;
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-wrap align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="bi bi-calendar-event me-1"></i>
                    <span class="utc-timestamp" data-utc-time="@summary.PeriodStartUtc.ToString("yyyy-MM-ddTHH:mm:ss")">@summary.PeriodStartUtc.ToString("g")</span>
                    &ndash;
                    <span class="utc-timestamp" data-utc-time="@summary.PeriodEndUtc.ToString("yyyy-MM-ddTHH:mm:ss")">@summary.PeriodEndUtc.ToString("g")</span>
                </h6>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-primary rounded-pill">@summary.EmailCount @Localizer["Emails"]</span>
                    <form asp-action="Delete" method="post" class="mb-0"
                          onsubmit="return confirm('@Localizer["SummaryDeleteConfirm"]');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@summary.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="@Localizer["Delete"]">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
            <div class="card-body">
                @if (!summary.IsSuccess)
                {
                    <div class="alert alert-danger mb-0">
                        <i class="bi bi-x-circle-fill me-2"></i>@Localizer["SummaryFailed"]:
                        <code>@summary.ErrorMessage</code>
                    </div>
                }
                else if (summary.EmailCount == 0)
                {
                    <p class="text-muted mb-0"><i class="bi bi-inbox me-2"></i>@Localizer["NoEmailsInPeriod"]</p>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(summary.OverviewText))
                    {
                        <p class="lead">@summary.OverviewText</p>
                    }

                    @foreach (var item in display.Items)
                    {
                        <div class="border-start border-3 ps-3 mb-3 @(item.Category == SummaryItemCategory.Urgent ? "border-danger" : item.Category == SummaryItemCategory.Action ? "border-warning" : "border-secondary")">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                <span class="badge @CategoryBadgeClass(item.Category)">@CategoryLabel(item.Category)</span>
                                <strong>@item.Title</strong>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Text))
                            {
                                <p class="mb-1">@item.Text</p>
                            }
                            @if (item.Emails.Any())
                            {
                                <div class="small">
                                    @foreach (var email in item.Emails)
                                    {
                                        <a asp-controller="Emails" asp-action="Details" asp-route-id="@email.Id"
                                           class="d-inline-block me-3 text-decoration-none" title="@email.From">
                                            <i class="bi bi-envelope-open me-1"></i>@email.Subject
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="card-footer text-muted small">
                @Localizer["CreatedAt"]:
                <span class="utc-timestamp" data-utc-time="@summary.CreatedAtUtc.ToString("yyyy-MM-ddTHH:mm:ss")">@summary.CreatedAtUtc.ToString("g")</span>
                @if (!string.IsNullOrEmpty(summary.Model))
                {
                    <span class="ms-2"><i class="bi bi-cpu me-1"></i>@summary.Model</span>
                }
            </div>
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Summary pages">
            <ul class="pagination justify-content-center">
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
